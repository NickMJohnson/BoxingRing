# Test configurations to run (change NBOXERS / NROUNDS below for each):
#   (2, 1) — minimal case: one fight, one round
#   (2, 3) — small tournament, multiple rounds
#   (4, 1) — single round, two simultaneous pairs
#   (4, 3) — three rounds with two pairs each
#   (6, 2) — three pairs per round
#   (6, 4) — larger state space
import ring

const NBOXERS = 6
const NROUNDS = 4
assert NBOXERS % 2 == 0

my_ring = ring.Ring(NBOXERS)

# One boxer thread: enter, fight, exit — once per round.
def boxer(boxer_id):
    for round in { 1 .. NROUNDS }:
        ring.enter(?my_ring, round)
        ring.exit(?my_ring)

for i in { 0 .. NBOXERS - 1 }:
    spawn boxer(i)
